# =============================================================================
# Integrador Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.
# Development defaults are built into docker-compose.yml, so this file is
# only required for production or custom setups.
#
# WARNING: Never commit a .env file with real secrets to version control.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=menu_ops

# -- JWT Authentication -------------------------------------------------------
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ISSUER=menu-ops
JWT_AUDIENCE=menu-ops-users
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_TABLE_TOKEN_EXPIRE_HOURS=3

# -- Table Token (HMAC for pwaMenu diners) ------------------------------------
# MUST be at least 32 characters. Generate with: openssl rand -hex 32
TABLE_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# -- SSL / Let's Encrypt ------------------------------------------------------
# Domain name for SSL certificate (must have DNS A record pointing to server)
DOMAIN=yourdomain.com
# Email for Let's Encrypt notifications (expiry warnings, etc.)
CERT_EMAIL=admin@yourdomain.com
# CORS allowed origins (must include https:// prefix in production)
ALLOWED_ORIGINS=https://yourdomain.com

# -- Cookie Security ----------------------------------------------------------
COOKIE_SECURE=true

# -- pgAdmin ------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# -- Monitoring (Grafana) ----------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
