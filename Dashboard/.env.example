# Buen Sabor Dashboard - Environment Variables
# Copy this file to .env and update with your values

# =============================================================================
# BACKEND API
# =============================================================================
# Base URL for the backend API
# Development: http://localhost:8000
# Production: https://api.buensabor.com
VITE_API_URL=http://localhost:8000

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=

# Mixpanel Project Token
# VITE_MIXPANEL_TOKEN=

# Custom analytics endpoint (if using custom solution)
# VITE_ANALYTICS_ENDPOINT=

# =============================================================================
# ERROR TRACKING (Optional)
# =============================================================================
# Sentry DSN for error tracking
# VITE_SENTRY_DSN=

# Sentry environment name
# VITE_SENTRY_ENVIRONMENT=production

# LogRocket App ID
# VITE_LOGROCKET_APP_ID=

# =============================================================================
# AUTHENTICATION (When backend is ready)
# =============================================================================
# OAuth client IDs
# VITE_GOOGLE_CLIENT_ID=
# VITE_FACEBOOK_APP_ID=

# JWT token expiration (in seconds)
# VITE_TOKEN_EXPIRY=3600

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features without code changes
VITE_FEATURE_ANALYTICS=false
VITE_FEATURE_ERROR_TRACKING=false
VITE_FEATURE_PUSH_NOTIFICATIONS=false

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Current environment: development | staging | production
VITE_ENVIRONMENT=development

# Enable debug logging
VITE_DEBUG_MODE=true

# =============================================================================
# PWA
# =============================================================================
# Service worker update check interval (in milliseconds)
# Default: 60000 (1 minute)
VITE_SW_UPDATE_INTERVAL=60000

# =============================================================================
# LOCALIZATION
# =============================================================================
# Default language: es | en | pt
VITE_DEFAULT_LOCALE=es

# Available languages (comma-separated)
VITE_AVAILABLE_LOCALES=es,en,pt
