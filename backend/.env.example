# =============================================================================
# Integrador Backend - Environment Variables Example
# =============================================================================
# Copy this file to .env and update with your values.
# NEVER commit .env to version control!
#
# Generate secure secrets with:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/menu_ops

# S2.E — Database pool sizing for 100 concurrent users (per-instance limits).
# Total max DB connections from N backend replicas = (DB_POOL_SIZE + DB_MAX_OVERFLOW) * N
# With 2 replicas (prod): 25+25 * 2 = 100. Postgres prod max_connections=200 → ~20 conns
# margin for pgAdmin, monitoring exporters, and ad-hoc queries.
# DB_POOL_TIMEOUT: how long a request waits for a free connection before erroring.
# DB_POOL_RECYCLE: rotate connections every N seconds to handle NAT/network blips.
# See devOps/RUNBOOK.md "Database connection pool" for full sizing rationale.
DB_POOL_SIZE=25
DB_MAX_OVERFLOW=25
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# NOTE: Docker Compose exposes Redis on port 6380 (not the default 6379)
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# JWT Configuration (CRITICAL - Change in production!)
# -----------------------------------------------------------------------------
# S3.2 — Strict validation.
#   • In ENVIRONMENT=production/prod/staging the app REFUSES TO START when this
#     value is empty, shorter than 32 chars, or one of the known insecure
#     defaults (e.g. "dev-secret-change-me-in-production", "changeme", ...).
#   • In ENVIRONMENT=dev/development/test/testing/local an empty value is
#     auto-replaced at boot with an ephemeral random secret (logged at WARN
#     level). The secret does not persist across restarts — set it explicitly
#     here for stable dev tokens.
# Generate a real secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openssl rand -hex 32
JWT_SECRET=
JWT_ISSUER=menu-ops
JWT_AUDIENCE=menu-ops-users

# Table token for diner authentication (HMAC).
# Same strict-validation rules as JWT_SECRET above. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
TABLE_TOKEN_SECRET=

# Token lifetimes (SEC-01: Short-lived access tokens reduce exposure window)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Table token expiration (reduced from 8h for security)
JWT_TABLE_TOKEN_EXPIRE_HOURS=3

# S1.2 — Refresh token migration to cookie-only.
# When True (default), /auth/login and /auth/refresh return the refresh_token BOTH
# in the HttpOnly cookie AND in the response body (legacy behavior, deprecated).
# Set to False once all frontends are confirmed to use the HttpOnly cookie only
# (no localStorage reads of `refresh_token`). Each legacy response logs a warning.
LEGACY_REFRESH_IN_BODY=true

# S1.3 — Legacy HMAC table tokens. Default True for backward compat.
# When True, the backend accepts legacy HMAC-format table tokens (no iss/aud/jti,
# unrevocable) in addition to the JWT format. Each acceptance logs a deprecation
# warning with session_id/table_id for triage.
# Set to false once all clients (pwaMenu) regenerate tokens to JWT format and
# backend logs show zero deprecation warnings for one week.
ALLOW_LEGACY_TABLE_TOKENS=true

# -----------------------------------------------------------------------------
# TOTP / 2FA encryption (S1.1.A)
# -----------------------------------------------------------------------------
# 32-byte URL-safe base64 Fernet key. Used to encrypt TOTP secrets at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production. Optional in dev (2FA disabled if missing).
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=60

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
WS_MAX_CONNECTIONS_PER_USER=5
WS_HEARTBEAT_TIMEOUT=60
WS_MAX_MESSAGE_SIZE=65536

# -----------------------------------------------------------------------------
# Server Ports
# -----------------------------------------------------------------------------
REST_API_PORT=8000
WS_GATEWAY_PORT=8001

# -----------------------------------------------------------------------------
# Ollama (RAG Chatbot)
# -----------------------------------------------------------------------------
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=qwen2.5:7b

# -----------------------------------------------------------------------------
# Mercado Pago (Payments) - Leave empty to disable
# -----------------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_NOTIFICATION_URL=

# -----------------------------------------------------------------------------
# Frontend URLs
# -----------------------------------------------------------------------------
BASE_URL=http://localhost:5176

# -----------------------------------------------------------------------------
# SMTP (optional — email features are disabled if not configured)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# -----------------------------------------------------------------------------
# CORS (Production only - comma-separated list)
# -----------------------------------------------------------------------------
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# -----------------------------------------------------------------------------
# AFIP Electronic Invoicing (S3.1)
# -----------------------------------------------------------------------------
# Controls the AFIP WSFE integration mode:
#   stub       (default) Simulated CAE for dev/test ONLY. The app FAILS TO START
#              if ENVIRONMENT=production while this is 'stub', and the invoice
#              endpoint returns HTTP 503 in production at request time.
#   production Real AFIP WSFE call. Requires pyafipws + AFIP certificates
#              (CN, CRT, KEY). NOT YET IMPLEMENTED — the service raises
#              NotImplementedError until the real integration ships.
AFIP_ENVIRONMENT=stub
